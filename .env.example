# Autenticação
# SESSION_SECRET assina o cookie de sessão. SEM ELE o app usa um segredo padrão
# conhecido e qualquer um consegue forjar uma sessão de administrador — defina
# também na Vercel. Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=troque-por-uma-chave-aleatoria-longa
MASTER_EMAIL=joaoromaodev@gmail.com
MASTER_PASSWORD=admin1234

# Chave da API do Google AI Studio (https://aistudio.google.com/apikey)
# Opcional se a chave estiver cadastrada na aba "Config" da planilha.
GEMINI_API_KEY=
GEMINI_MODELO=gemini-2.5-flash

# ID da planilha do Google usada como banco de dados
GOOGLE_SHEETS_ID=

# Conta de serviço (a planilha deve estar compartilhada com ela como editor):
# - LOCAL: caminho do arquivo JSON
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
# - DEPLOY (Vercel): cole o JSON inteiro numa única variável (deixe FILE vazio)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Supabase — banco do módulo Livro Caixa (a folha de ponto continua no Sheets).
# A URL e a publishable key podem ir para o navegador; a secret key é só de
# servidor (nunca prefixar com NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
